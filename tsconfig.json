{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    /* C'est ici que la magie opère pour ton JSON */
    "resolveJsonModule": true, 
    "esModuleInterop": true,
    
    "moduleDetection": "force",
    
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "include": ["**/*.ts", "user.json"], 
  "exclude": ["node_modules"]
}